---
# Keep ansible-lint focused on our source tree, not vendored dependencies or
# packaged artifacts that may exist under collections/.
exclude_paths:
  - .ansible/
  - collections/
  - .pre-commit-config.yaml
  # ansible-lint 6.x uses a stale role metadata schema that rejects supported
  # platform labels such as EL 10 and Ubuntu jammy. Collection packaging still
  # validates collection-level metadata via galaxy.yml and build/install smoke.
  - roles/*/meta/main.yml
