{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":semanticCommitType(chore)",
    ":semanticCommitScope(deps)"
  ],
  "renovate-config": {
    "enabled": false
  },
  "labels": ["dependencies", "renovate"],
  "baseBranchPatterns": ["develop"],
  "timezone": "UTC",
  "schedule": [],
  "rebaseWhen": "behind-base-branch",
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "description": "Automerge safe non-major updates into develop after CI passes",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest", "pinDigest"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Require manual approval for major updates",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Keep community.general on 11.x for linux_system_roles compatibility",
      "matchDepNames": ["community.general"],
      "matchDatasources": ["galaxy-collection"],
      "allowedVersions": "/^11\\./"
    },
    {
      "description": "Pin community.vmware to 5.10.0 for ansible-core 2.18.13 compatibility",
      "matchDepNames": ["community.vmware"],
      "matchDatasources": ["galaxy-collection"],
      "allowedVersions": "/^5\\.10\\.0$/"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "ee-wunder-devtools-ubi9 image tag in collection docs and helper scripts",
      "managerFilePatterns": [
        "/^scripts\\/.*\\.sh$/",
        "/^README\\.md$/",
        "/^CONTRIBUTING\\.md$/",
        "/^AGENTS\\.md$/",
        "/^\\.github\\/workflows\\/.*\\.ya?ml$/",
        "/^\\.pre-commit-config\\.ya?ml$/"
      ],
      "matchStrings": [
        "quay\\.io/l-it/ee-wunder-devtools-ubi9:v(?<currentValue>[0-9.]+)"
      ],
      "datasourceTemplate": "docker",
      "packageNameTemplate": "quay.io/l-it/ee-wunder-devtools-ubi9"
    }
  ]
}
